<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Créer une offre de stage - BHStage</title>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/creer-offre.css">
</head>
<body>

    <!-- OVERLAY -->
<div id="menu-overlay" class="menu-overlay"></div>

<!-- MENU BURGER -->
<div id="menu-burger" class="menu-burger">

    <button id="close-menu" class="close-btn">✕</button>

    <div class="menu-content">

        <a href="index.php">🏠 Accueil</a>
        <a href="index.php?page=offres">💼 Offres de stages</a>
        <a href="index.php?page=entreprises">🏢 Entreprises</a>

        {% if session.user is defined %}

            {% if session.user.role == 'etudiant' %}
                <a href="index.php?page=wishlist">❤️ Ma Wish-list</a>
                <a href="index.php?page=mes-candidatures">📄 Mes candidatures</a>

            {% elseif session.user.role == 'recruteur' %}
                <a href="index.php?page=gestion-etudiants">🎓 Gestion des étudiants</a>

            {% elseif session.user.role == 'admin' %}
                <a href="index.php?page=gestion-pilotes">👨‍✈️ Gestion des pilotes</a>
                <a href="index.php?page=gestion-etudiants">🎓 Gestion des étudiants</a>

            {% endif %}

        {% endif %}

    </div>

    <a href="index.php?page=logout" class="btn-logout">
        🔴 Déconnexion
    </a>

</div>

<!-- HEADER -->
<header class="entete">
    <div class="logo">
        <a href="index.php">
            <img src="/images/allostage.png" alt="Accueil AlloStage" class="logo-img">
        </a>
    </div>

    <nav class="navigation">
        <ul>
            <li><a href="index.php" class="actif">Accueil</a></li>
            <li><a href="index.php?page=offres">Offres de stages</a></li>
            <li><a href="index.php?page=entreprises">Entreprises</a></li>

            {% if session.user is defined and session.user.role == 'etudiant' %}
                <li><a href="index.php?page=wishlist">Ma Wish-list</a></li>
            {% endif %}
        </ul>
    </nav>

    <div class="actions-entete">
        {% if session.user is defined %}
            <button id="open-menu" class="btn-principal">
                Espace {{ session.user.role_label ?? session.user.role|capitalize }} ▾
            </button>
        {% else %}
            <a href="index.php?page=connexion" class="btn-connexion">
                Se connecter
            </a>
        {% endif %}
    </div>
</header>

    <main class="page-wrapper">
        <section class="form-card">

            <div class="form-header">
                <h1>Ajouter une offre de stage</h1>
                <p>Remplissez les informations ci-dessous pour publier une nouvelle offre.</p>
            </div>

            <form class="offer-form"
                  action="index.php?page=offre-creer"
                  method="POST">

                <div class="form-group full-width">
                    <label for="titre">Titre de l'offre *</label>
                    <input type="text" id="titre" name="titre"
                           value="{{ old.titre|default('')|e }}"
                           placeholder="Ex: Développeur Full Stack stagiaire" required>
                </div>

                <div class="form-grid">
                    <div class="form-group">
                        <label for="competence">Compétence recherchée *</label>
                        <input type="text" id="competence" name="competence"
                               value="{{ old.competence|default('')|e }}"
                               placeholder="Ex: PHP, SQL, Angular..." required>
                    </div>

                    <div class="form-group">
                        <label for="type_offre">Type d'offre *</label>
                        <input type="text" id="type_offre" name="type_offre"
                               value="{{ old.type_offre|default('')|e }}"
                               placeholder="Ex: Stage, Alternance" required>
                    </div>

                    <div class="form-group">
                        <label for="duree_stage">Durée du stage (semaines) *</label>
                        <input type="number" id="duree_stage" name="duree_stage"
                               value="{{ old.duree_stage|default('') }}"
                               placeholder="Ex: 6" required>
                    </div>

                    <div class="form-group">
                        <label for="remuneration">Rémunération €/mois *</label>
                        <input type="number" id="remuneration" name="remuneration" step="0.01"
                               value="{{ old.remuneration|default('') }}"
                               placeholder="Ex: 600" required>
                    </div>

                    <div class="form-group full-grid">
                        <label for="id_entreprise">Entreprise *</label>
                        <select id="id_entreprise" name="id_entreprise" required>
                            <option value="">Sélectionner une entreprise</option>
                            {% for e in entreprises %}
                                <option value="{{ e.id_entreprise }}"
                                    {% if old.id_entreprise is defined and old.id_entreprise == e.id_entreprise %}selected{% endif %}>
                                    {{ e.nom_entreprise }} - {{ e.ville }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                </div>

                <div class="form-group full-width">
                    <label for="description">Description de l'offre *</label>
                    <textarea id="description" name="description" rows="7"
                              placeholder="Décrivez les missions, le profil recherché, les outils utilisés..."
                              required>{{ old.description|default('')|e }}</textarea>
                </div>

                <div class="form-actions">
                    <button type="button" class="btn btn-cancel" onclick="history.back()">Annuler</button>
                    <button type="submit" class="btn btn-submit">Créer l'offre</button>
                </div>

            </form>
        </section>
    </main>

</body>
<script>
const openBtn  = document.getElementById('open-menu');
const closeBtn = document.getElementById('close-menu');
const menu     = document.getElementById('menu-burger');
const overlay  = document.getElementById('menu-overlay');

function openMenu() {
    menu.classList.add('active');
    overlay.classList.add('active');
}

function closeMenu() {
    menu.classList.remove('active');
    overlay.classList.remove('active');
}

if (openBtn)  openBtn.addEventListener('click', openMenu);
if (closeBtn) closeBtn.addEventListener('click', closeMenu);
if (overlay)  overlay.addEventListener('click', closeMenu);
</script>
</html>