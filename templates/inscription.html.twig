<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Inscription - BHStage</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    {# On pointe vers ton fichier CSS principal #}
    <link rel="stylesheet" href="/css/inscription.css">
</head>
<body>

<div class="login-container">

    <div class="logo-section">
        {# Correction du chemin pour le logo #}
        <img src="/images/allostage.png" alt="Logo BHStage" class="logo-img">
    </div>

    <div class="header-text">
        <h2>S'inscrire</h2>
        <p>Créez votre compte pour accéder aux offres.</p>
    </div>

    {# --- AFFICHAGE DES ERREURS (Indispensable pour le PHP) --- #}
    {% if erreurs is defined and erreurs %}
        <ul class="liste-erreurs" style="color: #ff4757; margin-bottom: 20px; list-style: none; font-size: 14px; padding: 0;">
        {% for e in erreurs %}
            <li><i class="fas fa-exclamation-circle"></i> {{ e }}</li>
        {% endfor %}
        </ul>
    {% endif %}

    {# --- FORMULAIRE VERS TON CONTROLLER PHP --- #}
    <form class="login-form" action="index.php?page=inscription" method="POST">

        <div class="input-group">
            <label for="nom">Nom</label>
            <input type="text" id="nom" name="nom" placeholder="Votre nom" required value="{{ old.nom ?? '' }}">
        </div>

        <div class="input-group">
            <label for="prenom">Prénom</label>
            <input type="text" id="prenom" name="prenom" placeholder="Votre prénom" required value="{{ old.prenom ?? '' }}">
        </div>

        <div class="input-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" placeholder="Votre adresse mail" required value="{{ old.email ?? '' }}">
        </div>

        <div class="input-group">
            <label for="role">Type de compte</label>
            <select name="role" id="role" class="champ-saisie" style="width: 100%; border: none; border-bottom: 1px solid #e2e8f0; padding-bottom: 10px; font-size: 14px; outline: none; background: transparent; color: #6c757d;">
                <option value="1" {{ (old.role ?? '') == '1' ? 'selected' : '' }}>Étudiant</option>
                <option value="2" {{ (old.role ?? '') == '2' ? 'selected' : '' }}>Recruteur</option>
                <option value="3" {{ (old.role ?? '') == '3' ? 'selected' : '' }}>Admin</option>
            </select>
        </div>

        <div class="input-group">
            <label for="mot_de_passe">Mot de passe</label>
            <div class="password-wrapper">
                <input type="password" id="mot_de_passe" name="mot_de_passe" placeholder="Votre mot de passe" required>
                <i class="fas fa-eye" id="icone-oeil-1" style="cursor: pointer;"></i>
            </div>
        </div>

        <div class="input-group">
            <label for="confirm_mot_de_passe">Confirmer le mot de passe</label>
            <div class="password-wrapper">
                <input type="password" id="confirm_mot_de_passe" name="mot_de_passe_confirm" placeholder="Confirmer votre mot de passe" required>
                <i class="fas fa-eye" id="icone-oeil-2" style="cursor: pointer;"></i>
            </div>
        </div>

        <div class="checkbox-group" style="margin-top: 15px; font-size: 13px;">
            <input type="checkbox" id="conditions" name="conditions" required>
            <label for="conditions">
                J'accepte les <a href="index.php?page=conditions" style="color: #A8C6FA;">Conditions d'utilisation</a>
                et la <a href="index.php?page=politique" style="color: #A8C6FA;">Politique de confidentialité</a>
            </label>
        </div>

        <button type="submit" class="btn-submit">Continuer</button>

    </form>

    <div class="signup-link">
        <p>Vous avez déjà un compte ? <a href="index.php?page=connexion">Se connecter</a></p>
    </div>

    <div class="footer-bottom">
        <a href="index.php?page=mentions" class="legal-link">Mentions légales</a>
    </div>

</div>

<script>
    // GESTION DES YEUX (MOT DE PASSE ET CONFIRMATION)
    function togglePassword(iconId, inputId) {
        const icon = document.getElementById(iconId);
        const input = document.getElementById(inputId);
        icon.addEventListener('click', function () {
            const type = input.getAttribute('type') === 'password' ? 'text' : 'password';
            input.setAttribute('type', type);
            this.classList.toggle('fa-eye');
            this.classList.toggle('fa-eye-slash');
        });
    }

    togglePassword('icone-oeil-1', 'mot_de_passe');
    togglePassword('icone-oeil-2', 'confirm_mot_de_passe');
</script>

</body>
</html>