<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Inscription - AlloStage</title>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="/css/inscription.css">
</head>

<body>

<div class="login-container">

    <!-- LOGO -->
    <div class="logo-section">
        <img src="/images/allostage.png" alt="Logo AlloStage" class="logo-img">
    </div>

    <!-- TITRE -->
    <div class="header-text">
        <h2>Création d'un compte</h2>
    </div>

    <!-- MESSAGE ADMIN -->
    {% if session.user is defined and session.user.role == 'admin' %}
        <p style="color: var(--bleu-allostage); margin-bottom: 10px;">
            Création d’un compte par un administrateur
        </p>
    {% endif %}

    <!-- ERREURS -->
    {% if erreurs is defined and erreurs %}
        <ul class="liste-erreurs" style="color: #ff4757; margin-bottom: 20px; list-style: none; font-size: 14px; padding: 0;">
            {% for e in erreurs %}
                <li><i class="fas fa-exclamation-circle"></i> {{ e }}</li>
            {% endfor %}
        </ul>
    {% endif %}

    <!-- FORMULAIRE -->
    <form class="login-form" action="index.php?page=inscription" method="POST">

        <!-- 🔁 REDIRECTION -->
        {% if redirect is defined %}
            <input type="hidden" name="redirect" value="{{ redirect }}">
        {% endif %}

        <!-- NOM -->
        <div class="input-group">
            <label for="nom">Nom</label>
            <input type="text" id="nom" name="nom" placeholder="Nom" required value="{{ old.nom ?? '' }}">
        </div>

        <!-- PRENOM -->
        <div class="input-group">
            <label for="prenom">Prénom</label>
            <input type="text" id="prenom" name="prenom" placeholder="Prénom" required value="{{ old.prenom ?? '' }}">
        </div>

        <!-- EMAIL -->
        <div class="input-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" placeholder="Adresse mail" required value="{{ old.email ?? '' }}">
        </div>

        <!-- ROLE -->
        <div class="input-group">
            <label for="role">Type de compte</label>

            {% if session.user is defined and session.user.role == 'admin' %}

                <select name="role" id="role" class="champ-saisie"
                        style="width: 100%; border: none; border-bottom: 1px solid #e2e8f0; padding-bottom: 10px; font-size: 14px; outline: none; background: transparent; color: #6c757d;">

                    <option value="etudiant" {{ (old.role ?? '') == 'etudiant' ? 'selected' : '' }}>
                        Étudiant
                    </option>

                    <option value="pilote" {{ (old.role ?? '') == 'pilote' ? 'selected' : '' }}>
                        Pilote
                    </option>

                </select>

            {% else %}

                <input type="hidden" name="role" value="etudiant">
                <input type="text" value="Étudiant" disabled class="champ-saisie"
                       style="width: 100%; border: none; border-bottom: 1px solid #e2e8f0; padding-bottom: 10px; font-size: 14px; outline: none; background: transparent; color: #6c757d;">

            {% endif %}

        </div>

        <!-- MOT DE PASSE -->
        <div class="input-group">
            <label for="mot_de_passe">Mot de passe</label>
            <div class="password-wrapper">
                <input type="password" id="mot_de_passe" name="mot_de_passe" placeholder="Mot de passe" required>
                <i class="fas fa-eye" id="icone-oeil-1" style="cursor: pointer;"></i>
            </div>
        </div>

        <!-- CONFIRMATION -->
        <div class="input-group">
            <label for="confirm_mot_de_passe">Confirmer le mot de passe</label>
            <div class="password-wrapper">
                <input type="password" id="confirm_mot_de_passe" name="mot_de_passe_confirm" placeholder="Confirmer" required>
                <i class="fas fa-eye" id="icone-oeil-2" style="cursor: pointer;"></i>
            </div>
        </div>

        <!-- CONDITIONS -->
        <div class="checkbox-group" style="margin-top: 15px; font-size: 13px;">
            <input type="checkbox" id="conditions" name="conditions" required>
            <label for="conditions">
                J'accepte les 
                <a href="index.php?page=conditions" style="color: #A8C6FA;">Conditions d'utilisation</a>
                et la 
                <a href="index.php?page=politique" style="color: #A8C6FA;">Politique de confidentialité</a>
            </label>
        </div>

        <!-- BOUTON -->
        <button type="submit" class="btn-submit">Continuer</button>

    </form>

    <!-- LIEN CONNEXION -->
    <div class="signup-link">
        <p>Vous avez déjà un compte ? <a href="index.php?page=connexion">Se connecter</a></p>
    </div>

    <!-- FOOTER -->
    <div class="footer-bottom">
        <a href="index.php?page=mentions" class="legal-link">Mentions légales</a>
    </div>

</div>

<!-- SCRIPT -->
<script>
function togglePassword(iconId, inputId) {
    const icon = document.getElementById(iconId);
    const input = document.getElementById(inputId);

    icon.addEventListener('click', function () {
        const type = input.getAttribute('type') === 'password' ? 'text' : 'password';
        input.setAttribute('type', type);
        this.classList.toggle('fa-eye');
        this.classList.toggle('fa-eye-slash');
    });
}

togglePassword('icone-oeil-1', 'mot_de_passe');
togglePassword('icone-oeil-2', 'confirm_mot_de_passe');
</script>

</body>
</html>