<!DOCTYPE html>
<html lang="fr-FR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Offres de stage - AlloStage</title>

    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/liste-offres.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>

<body>

<!-- OVERLAY -->
<div id="menu-overlay" class="menu-overlay"></div>

<!-- MENU BURGER -->
<div id="menu-burger" class="menu-burger">

    <button id="close-menu" class="close-btn">✕</button>

    <div class="menu-content">

        <a href="index.php">🏠 Accueil</a>
        <a href="index.php?page=offres">💼 Offres de stages</a>
        <a href="index.php?page=entreprises">🏢 Entreprises</a>

        {% if session.user is defined %}

            {% if session.user.role == 'etudiant' %}
                <a href="index.php?page=wishlist">❤️ Ma Wish-list</a>
                <a href="index.php?page=mes-candidatures">📄 Mes candidatures</a>

            {% elseif session.user.role == 'recruteur' %}
                <a href="index.php?page=gestion-etudiants">🎓 Gestion des étudiants</a>
                <a href="index.php?page=gestion-entreprises">🏢 Gestion des entreprises</a>
                <a href="index.php?page=gestion-offres">💼 Gestion des offres</a>
            {% elseif session.user.role == 'admin' %}
                <a href="index.php?page=gestion-pilotes">👨‍✈️ Gestion des pilotes</a>
                <a href="index.php?page=gestion-etudiants">🎓 Gestion des étudiants</a>
                <a href="index.php?page=gestion-entreprises">🏢 Gestion des entreprises</a>
                <a href="index.php?page=gestion-offres">💼 Gestion des offres</a>
            {% endif %}

        {% endif %}

    </div>

    <a href="index.php?page=logout" class="btn-logout">
        🔴 Déconnexion
    </a>

</div>

<!-- HEADER -->
<header class="entete">
    <div class="logo">
        <a href="index.php">
            <img src="/images/allostage.png" alt="Accueil AlloStage" class="logo-img">
        </a>
    </div>

    <nav class="navigation">
        <ul>
            <li><a href="index.php">Accueil</a></li>
            <li><a href="index.php?page=offres" class="actif">Offres de stages</a></li>
            <li><a href="index.php?page=entreprises">Entreprises</a></li>

            {% if session.user is defined and session.user.role == 'etudiant' %}
                <li><a href="index.php?page=wishlist">Ma Wish-list</a></li>
                <li><a href="index.php?page=mes-candidatures">Mes candidatures</a></li>
            {% endif %}
        </ul>
    </nav>

    <div class="actions-entete">
        {% if session.user is defined %}
            <button id="open-menu" class="btn-principal">
                Espace {{ session.user.role_label ?? session.user.role|capitalize }} ▾
            </button>
        {% else %}
            <a href="index.php?page=connexion" class="btn-connexion">
                Se connecter
            </a>
        {% endif %}
    </div>
</header>
<main class="contenu fond-gris">

    <!-- TITRE -->
    <section class="en-tete-recherche">
        <h1>Trouvez le stage de vos rêves</h1>
        <p>{{ nombre_offres }} offres disponibles</p>
    </section>

    <!-- FILTRES -->
    <section class="barre-recherche">
        <form method="GET" action="index.php" class="form-recherche">

            <input type="hidden" name="page" value="offres">

            <input type="text" name="recherche" placeholder="Nom du poste..."
                   value="{{ filtres.recherche }}">

            <select name="competence">
                <option value="">Toutes les compétences</option>
                {% for comp in competences %}
                    <option value="{{ comp }}" {% if filtres.competence == comp %}selected{% endif %}>
                        {{ comp }}
                    </option>
                {% endfor %}
            </select>

            <select name="ville">
                <option value="">Toutes les villes</option>
                {% for v in villes %}
                    <option value="{{ v }}" {% if filtres.ville == v %}selected{% endif %}>
                        {{ v }}
                    </option>
                {% endfor %}
            </select>

            <button type="submit" class="btn-rechercher">Rechercher</button>

        </form>
    </section>

    <!-- LISTE -->
    <section class="conteneur-liste">

        <div class="grille-offres">

            {% for offre in offres %}
            <article class="carte-offre">
                <div class="en-tete-carte">
                    {% if session.user is defined %}
                        <a href="index.php?page=wishlist-ajouter&id={{ offre.id_offre }}" 
                           class="btn-favori {{ (ids_wishlist is defined and offre.id_offre in ids_wishlist) ? 'actif' : '' }}">
                            <i class="fas fa-heart"></i>
                        </a>
                    {% else %}
                        <a href="index.php?page=connexion" class="btn-favori">
                            <i class="fas fa-heart"></i>
                        </a>
                    {% endif %}
                </div>

                <h3 class="titre-offre">{{ offre.titre }}</h3>

                <p class="entreprise-offre">
                    <strong>{{ offre.nom_entreprise }}</strong> • {{ offre.ville }}
                </p>

                <div class="tags-offre">
                    <span class="tag">📅 {{ offre.duree_stage }} semaines</span>
                    <span class="tag">🛠 {{ offre.competence }}</span>
                </div>

                <p class="description">
                    {{ offre.description|slice(0, 120) ~ '...' }}
                </p>

                <div class="actions-carte">
                    <a href="index.php?page=offre&id={{ offre.id_offre }}" class="btn-secondaire">
                        Détails
                    </a>
                
                </div>

            </article>

            {% else %}
                <p>Aucune offre trouvée.</p>
            {% endfor %}

        </div>

        <!-- PAGINATION IDENTIQUE ENTREPRISE -->
        <nav class="pagination">

            {% if page > 1 %}
                <a href="index.php?page=offres&p={{ page - 1 }}
                {% if filtres.recherche %}&recherche={{ filtres.recherche }}{% endif %}
                {% if filtres.competence %}&competence={{ filtres.competence }}{% endif %}
                {% if filtres.ville %}&ville={{ filtres.ville }}{% endif %}"
                class="page-lien">
                    ← Précédent
                </a>
            {% else %}
                <span class="page-lien desactive">← Précédent</span>
            {% endif %}

            <span class="page-lien actif">
                Page {{ page }} / {{ totalPages }}
            </span>

            {% if page < totalPages %}
                <a href="index.php?page=offres&p={{ page + 1 }}
                {% if filtres.recherche %}&recherche={{ filtres.recherche }}{% endif %}
                {% if filtres.competence %}&competence={{ filtres.competence }}{% endif %}
                {% if filtres.ville %}&ville={{ filtres.ville }}{% endif %}"
                class="page-lien">
                    Suivant →
                </a>
            {% else %}
                <span class="page-lien desactive">Suivant →</span>
            {% endif %}

        </nav>

    </section>

</main>

<footer class="pied-de-page">
    <p>&copy; 2026 AlloStage</p>
</footer>
<script>
const openBtn  = document.getElementById('open-menu');
const closeBtn = document.getElementById('close-menu');
const menu     = document.getElementById('menu-burger');
const overlay  = document.getElementById('menu-overlay');

function openMenu() {
    menu.classList.add('active');
    overlay.classList.add('active');
}

function closeMenu() {
    menu.classList.remove('active');
    overlay.classList.remove('active');
}

if (openBtn)  openBtn.addEventListener('click', openMenu);
if (closeBtn) closeBtn.addEventListener('click', closeMenu);
if (overlay)  overlay.addEventListener('click', closeMenu);
</script>
</body>
</html>