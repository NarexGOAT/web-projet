<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Liste des offres - BHStage</title>
  <link rel="stylesheet" href="/css/liste-offres.css">
</head>
<body>
  <main class="page-offres">

    <header class="barre-haut">
      <a href="index.php" class="bouton-retour">←</a>
      <h1 class="titre-page">Liste des offres</h1>
      <a href="index.php?page=menu" class="bouton-profil">👤</a>
    </header>

    <section class="zone-intro">
      <p class="texte-intro">
        Consulte les offres de stage disponibles et affine ta recherche avec les filtres.
      </p>
    </section>

    <section class="zone-filtres">
      <h2>Filtres</h2>

      <form class="filtres" action="index.php" method="get">
  <input type="hidden" name="page" value="offres">
        <div class="champ-filtre">
          <label for="metier">Métier recherché</label>
          <input
            type="text"
            id="metier"
            name="metier"
            placeholder="Exemple : développeur web"
            value="{{ filtres.metier ?? '' }}"
          >
        </div>

        <div class="champ-filtre">
          <label for="ville">Ville</label>
          {% set v = filtres.ville ?? 'Toutes les villes' %}
          <select id="ville" name="ville">
            <option {{ v == 'Toutes les villes' ? 'selected' }}>Toutes les villes</option>
            {% for vi in villes %}
              <option {{ v == vi ? 'selected' }}>{{ vi }}</option>
            {% endfor %}
          </select>
        </div>

        <div class="champ-filtre">
          <label for="duree">Durée</label>
          {% set duree = filtres.duree ?? 'Toutes les durées' %}
          <select id="duree" name="duree">
            <option {{ duree == 'Toutes les durées' ? 'selected' }}>Toutes les durées</option>
            <option {{ duree == 'Moins de 2 mois' ? 'selected' }}>Moins de 2 mois</option>
            <option {{ duree == '2 à 4 mois' ? 'selected' }}>2 à 4 mois</option>
            <option {{ duree == '4 à 6 mois' ? 'selected' }}>4 à 6 mois</option>
            <option {{ duree == 'Plus de 6 mois' ? 'selected' }}>Plus de 6 mois</option>
          </select>
        </div>

        <div class="champ-filtre">
          <label for="competence">Compétence</label>
          {% set comp = filtres.competence ?? 'Toutes les compétences' %}
          <select id="competence" name="competence">
            <option {{ comp == 'Toutes les compétences' ? 'selected' }}>Toutes les compétences</option>
            {% for c in competences %}
              <option {{ comp == c ? 'selected' }}>{{ c }}</option>
            {% endfor %}
          </select>
        </div>

        <div class="champ-filtre">
          <label for="publication">Date de publication</label>
          {% set pub = filtres.publication ?? 'Toutes les dates' %}
          <select id="publication" name="publication">
            <option {{ pub == 'Toutes les dates' ? 'selected' }}>Toutes les dates</option>
            <option {{ pub == 'Aujourd’hui' ? 'selected' }}>Aujourd’hui</option>
            <option {{ pub == 'Cette semaine' ? 'selected' }}>Cette semaine</option>
            <option {{ pub == 'Ce mois-ci' ? 'selected' }}>Ce mois-ci</option>
          </select>
        </div>

        <div class="actions-filtres">
          <button type="submit" class="bouton-filtrer">Filtrer</button>
          <button type="reset" class="bouton-reinitialiser">Réinitialiser</button>
        </div>
      </form>
    </section>

    <section class="zone-resultats">
      <p class="nombre-resultats">
        {{ nombre_offres }} offres trouvées
      </p>

      <div class="liste-offres">

        {% for offre in offres %}
          <article class="ligne-offre">
            <div class="ligne-offre__contenu">
              <div class="ligne-offre__haut">
                <h2>{{ offre.titre }}</h2>
                <p class="etiquette-date">
                  Publiée le {{ offre.date_publication|date('d/m/Y') }}
                </p>
              </div>

              <p class="entreprise">
                {{ offre.nom_entreprise ?? 'Entreprise non renseignée' }}
                {% if offre.ville %}
                    {{ offre.ville }}
                {% endif %}
              </p>

              <p class="description">
                {{ offre.description }}
              </p>

              <div class="details">
                <span>⏳ {{ offre.duree_stage }} semaines</span>
                <span>💼 {{ offre.type_offre ?? 'Stage' }}</span>
                <span>🛠 {{ offre.competence }}</span>
              </div>
            </div>

            <div class="ligne-offre__actions">
              <a href="index.php?page=offre&id={{ offre.id_offre }}" class="bouton-voir">
                Voir l’offre
              </a>
            </div>
          </article>
        {% else %}
          <p>Aucune offre ne correspond à ces filtres.</p>
        {% endfor %}

      </div>
    </section>

  </main>
</body>
</html>