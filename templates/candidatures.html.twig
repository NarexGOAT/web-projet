<!DOCTYPE html>
<html lang="fr-FR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mes Candidatures - BHStage</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/candidatures.css">
</head>
<body>
    <header class="entete">
        <div class="logo">
            <a href="index.php">
                <img src="/images/allostage.png" alt="Accueil BHStage" class="logo-img" style="height: 70px; object-fit: contain;">
            </a>
        </div>
        <nav class="navigation">
            <ul>
                <li><a href="index.php">Accueil</a></li>
                <li><a href="index.php?page=offres">Offres de stages</a></li>
                <li><a href="index.php?page=entreprises">Entreprises</a></li>
                <li><a href="index.php?page=wishlist">Ma Wish-list</a></li>
                <li><a href="index.php?page=candidatures" class="actif">Mes Candidatures</a></li>
            </ul>
        </nav>
        <div class="actions-entete">
            <a href="index.php?page=menu" class="btn-secondaire">Mon Profil</a>
        </div>
    </header>

    <main class="contenu fond-gris">

        <section class="en-tete-recherche">
            <h1>Mes Candidatures 📂</h1>
            <p>Suivez l'état d'avancement des stages auxquels vous avez postulé et retrouvez vos documents envoyés.</p>
        </section>

        <section class="conteneur-liste">

            {% if candidatures is empty %}
                <p>Vous n'avez encore envoyé aucune candidature.</p>
            {% else %}
                <div class="grille-offres">
                    {% for c in candidatures %}
                        <article class="carte-offre">
                            <div class="en-tete-carte">
                                {% if c.statut is defined %}
                                    {% if c.statut == 'en_attente' %}
                                        <span class="badge-attente">⏳ En attente</span>
                                    {% elseif c.statut == 'entretien' %}
                                        <span class="badge-entretien">✅ Entretien programmé</span>
                                    {% elseif c.statut == 'refuse' %}
                                        <span class="badge-refus">❌ Refusé</span>
                                    {% else %}
                                        <span class="badge-attente">⏳ En attente</span>
                                    {% endif %}
                                {% else %}
                                    <span class="badge-attente">⏳ En attente</span>
                                {% endif %}
                            </div>

                            <h3 class="titre-offre">{{ c.titre }}</h3>

                            <p class="entreprise-offre">
                                <strong>{{ c.nom_entreprise ?? 'Entreprise' }}</strong>
                                {% if c.ville is defined and c.ville %}
                                    • {{ c.ville }}
                                {% endif %}
                            </p>

                            <p class="description" style="font-size: 0.9rem; color: #6c757d; margin-top: 1rem;">
                                Envoyé le : {{ c.date_envoi|date('d F Y') }}
                            </p>

                            <div class="actions-documents">
                                {% if c.cv is defined and c.cv %}
                                    <a href="{{ c.cv }}" class="btn-doc" target="_blank">📄 Voir mon CV</a>
                                {% else %}
                                    <span class="btn-doc">📄 CV indisponible</span>
                                {% endif %}

                                {% if c.lm is defined and c.lm %}
                                    <a href="{{ c.lm }}" class="btn-doc" target="_blank">✍️ Voir ma Lettre</a>
                                {% else %}
                                    <span class="btn-doc">✍️ Lettre indisponible</span>
                                {% endif %}
                            </div>
                        </article>
                    {% endfor %}
                </div>
            {% endif %}

        </section>
    </main>

    <footer class="pied-de-page">
        <p>&copy; 2026 BHStage. Tous droits réservés.</p>
    </footer>
</body>
</html>