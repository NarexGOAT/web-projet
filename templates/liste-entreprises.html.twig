<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Liste des entreprises - BHStage</title>
  <link rel="stylesheet" href="/public/css/liste-entreprises.css">
</head>
<body>
  <main class="page-entreprises">

    <header class="barre-haut">
      <a href="index.php" class="bouton-retour">←</a>
      <h1 class="titre-page">Liste des entreprises</h1>
      <a href="index.php?page=menu" class="bouton-profil">👤</a>
    </header>

    <section class="zone-intro">
      <p class="texte-intro">
        Découvre les entreprises partenaires qui proposent des stages et alternances.
      </p>
    </section>

    <section class="zone-filtres">
      <h2>Filtres</h2>

      <form class="filtres" action="index.php" method="get">
        <input type="hidden" name="page" value="entreprises">
        <div class="champ-filtre">
          <label for="nom">Nom de l’entreprise</label>
          <input
            type="text"
            id="nom"
            name="nom"
            placeholder="Exemple : OpenStage"
            value="{{ filtres.nom ?? '' }}"
          >
        </div>

        <div class="champ-filtre">
          <label for="domaine">Domaine</label>
          {% set dom = filtres.domaine ?? 'Tous les domaines' %}
          <select id="domaine" name="domaine">
            <option {{ dom == 'Tous les domaines' ? 'selected' }}>Tous les domaines</option>
            {% for d in domaines %}
              <option {{ dom == d ? 'selected' }}>{{ d }}</option>
            {% endfor %}
          </select>
        </div>

        <div class="champ-filtre">
          <label for="ville">Ville</label>
          {% set v = filtres.ville ?? 'Toutes les villes' %}
          <select id="ville" name="ville">
            <option {{ v == 'Toutes les villes' ? 'selected' }}>Toutes les villes</option>
            {% for vi in villes %}
              <option {{ v == vi ? 'selected' }}>{{ vi }}</option>
            {% endfor %}
          </select>
        </div>

        <div class="champ-filtre">
          <label for="taille">Taille</label>
            {% set ta = filtres.taille ?? 'Toutes les tailles' %}
            <select id="taille" name="taille">
              <option {{ ta == 'Toutes les tailles' ? 'selected' }}>Toutes les tailles</option>
              <option {{ ta == 'Petite entreprise' ? 'selected' }}>Petite entreprise</option>
              <option {{ ta == 'PME' ? 'selected' }}>PME</option>
              <option {{ ta == 'Grande entreprise' ? 'selected' }}>Grande entreprise</option>
            </select>
        </div>

        <div class="champ-filtre">
          <label for="offres">Nombre d’offres</label>
          {% set fOffres = filtres.offres ?? 'Peu importe' %}
          <select id="offres" name="offres">
            <option {{ fOffres == 'Peu importe' ? 'selected' }}>Peu importe</option>
            <option {{ fOffres == '0 offre' ? 'selected' }}>0 offre</option>
            <option {{ fOffres == '1 à 5 offres' ? 'selected' }}>1 à 5 offres</option>
            <option {{ fOffres == '6 à 10 offres' ? 'selected' }}>6 à 10 offres</option>
            <option {{ fOffres == 'Plus de 10 offres' ? 'selected' }}>Plus de 10 offres</option>
          </select>
        </div>

        <div class="actions-filtres">
          <button type="submit" class="bouton-filtrer">Filtrer</button>
          <a href="index.php?page=entreprises" class="bouton-reinitialiser">Réinitialiser</a>
        </div>
      </form>
    </section>

    <section class="zone-resultats">
      <p class="nombre-resultats">
        {{ nombre_entreprises }} entreprises trouvées
      </p>

      <div class="liste-entreprises">
        {% for entreprise in entreprises %}
          <article class="ligne-entreprise">
            <div class="ligne-entreprise__contenu">
              <div class="ligne-entreprise__haut">
                <div class="entreprise-entete">
                  <div class="entreprise-logo"></div>
                  <div>
                    <h2>{{ entreprise.nom_entreprise }}</h2>
                    <p class="secteur">{{ entreprise.domaine }}</p>
                  </div>
                </div>
              </div>

              <p class="description">
                {{ entreprise.description }}
              </p>

              <div class="details">
                <span>📍 {{ entreprise.ville }}</span>
                <span>🏢
                  {% if entreprise.taille is null %}
                    Taille non renseignée
                  {% elseif entreprise.taille < 50 %}
                     Petite entreprise ({{ entreprise.taille }} salariés)
                  {% elseif entreprise.taille < 250 %}
                    PME ({{ entreprise.taille }} salariés)
                  {% else %}
                    Grande entreprise ({{ entreprise.taille }} salariés)
                  {% endif %}
                </span>
                <span>📄 {{ entreprise.nb_offres }} offre(s)</span>
                <span>📧 {{ entreprise.email }}</span>
                <span>📞 {{ entreprise.telephone }}</span>
              </div>
            </div>

            <div class="ligne-entreprise__actions">
              <a href="index.php?page=entreprise&id={{ entreprise.id_entreprise }}" class="bouton-voir">
                Voir l'entreprise
              </a>
            </div>
          </article>
        {% else %}
          <p>Aucune entreprise ne correspond à ces filtres.</p>
        {% endfor %}
      </div>
    </section>

  </main>
</body>
</html>