<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Connexion - BHStage</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/css/connexion.css">
</head>
<body>

    <div class="login-container">
        {# --- NOUVEAU : BOUTON RETOUR --- #}
        <a href="index.php" class="btn-retour">
            <i class="fas fa-arrow-left"></i>
        </a>
        
        <div class="logo-section">
            <img src="/images/allostage.png" alt="Logo BHStage" class="logo-img">
        </div>

        <div class="header-text">
            <h2>Se connecter</h2>
            <p>Salut ! Ravi de vous revoir.</p>
        </div>

        {# --- AFFICHAGE DES ERREURS PHP --- #}
        {% if erreurs is defined and erreurs %}
            <ul class="liste-erreurs" style="color: #ff4757; margin-bottom: 20px; list-style: none; font-size: 14px; padding: 0;">
            {% for e in erreurs %}
                <li><i class="fas fa-exclamation-circle"></i> {{ e }}</li>
            {% endfor %}
            </ul>
        {% endif %}

        {# --- FORMULAIRE --- #}
        <form action="index.php?page=connexion" method="post" class="login-form">
            
            <div class="input-group">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" placeholder="Votre adresse mail" required value="{{ old.email ?? '' }}">
            </div>

            <div class="input-group">
                <label for="password">Mot de passe</label>
                <div class="password-wrapper">
                    <input type="password" id="password" name="mot_de_passe" placeholder="Votre mot de passe" required>
                    <i class="fas fa-eye" id="icone-oeil" style="cursor: pointer;"></i>
                </div>
            </div>

            <button type="submit" class="btn-submit">Se connecter</button>

        </form>

        <div class="footer-bottom">
            <a href="index.php?page=mentions" class="legal-link">Mentions légales</a>
        </div>
    </div>

    {# --- SCRIPT POUR L'OEIL DU MOT DE PASSE --- #}
    <script>
        const iconeOeil = document.getElementById('icone-oeil');
        const champMdp = document.getElementById('password');

        iconeOeil.addEventListener('click', function () {
            const type = champMdp.getAttribute('type') === 'password' ? 'text' : 'password';
            champMdp.setAttribute('type', type);
            
            // Change l'icône de l'oeil
            this.classList.toggle('fa-eye');
            this.classList.toggle('fa-eye-slash');
        });
    </script>

</body>
</html>