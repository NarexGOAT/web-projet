<!DOCTYPE html>
<html lang="fr-FR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ offre.titre }} - AlloStage</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/offre.css">
</head>

<body>

<!-- OVERLAY -->
<div id="menu-overlay" class="menu-overlay"></div>

<!-- MENU BURGER -->
<div id="menu-burger" class="menu-burger">

    <button id="close-menu" class="close-btn">✕</button>

    <div class="menu-content">

        <a href="index.php">🏠 Accueil</a>
        <a href="index.php?page=offres">💼 Offres de stages</a>
        <a href="index.php?page=entreprises">🏢 Entreprises</a>

        {% if session.user is defined %}

            {% if session.user.role == 'etudiant' %}
                <a href="index.php?page=wishlist">❤️ Ma Wish-list</a>
                <a href="index.php?page=mes-candidatures">📄 Mes candidatures</a>

            {% elseif session.user.role == 'recruteur' %}
                <a href="index.php?page=gestion-etudiants">🎓 Gestion des étudiants</a>
                <a href="index.php?page=gestion-entreprises">🏢 Gestion des entreprises</a>
                <a href="index.php?page=gestion-offres">💼 Gestion des offres</a>

            {% elseif session.user.role == 'admin' %}
                <a href="index.php?page=gestion-pilotes">👨‍✈️ Gestion des pilotes</a>
                <a href="index.php?page=gestion-etudiants">🎓 Gestion des étudiants</a>
                <a href="index.php?page=gestion-entreprises">🏢 Gestion des entreprises</a>
                <a href="index.php?page=gestion-offres">💼 Gestion des offres</a>
                
            {% endif %}

        {% endif %}

    </div>

    <a href="index.php?page=logout" class="btn-logout">
        🔴 Déconnexion
    </a>

</div>

<!-- HEADER -->
<header class="entete">
    <div class="logo">
        <a href="index.php">
            <img src="/images/allostage.png" alt="Accueil AlloStage" class="logo-img">
        </a>
    </div>

    <nav class="navigation">
        <ul>
            <li><a href="index.php">Accueil</a></li>
            <li><a href="index.php?page=offres" class="actif">Offres de stages</a></li>
            <li><a href="index.php?page=entreprises">Entreprises</a></li>

            {% if session.user is defined and session.user.role == 'etudiant' %}
                <li><a href="index.php?page=wishlist">Ma Wish-list</a></li>
                <li><a href="index.php?page=mes-candidatures">Mes candidatures</a></li>
            {% endif %}
        </ul>
    </nav>

    <div class="actions-entete">
        {% if session.user is defined %}
            <button id="open-menu" class="btn-principal">
                Espace {{ session.user.role_label ?? session.user.role|capitalize }} ▾
            </button>
        {% else %}
            <a href="index.php?page=connexion" class="btn-connexion">
                Se connecter
            </a>
        {% endif %}
    </div>
</header>

<main class="contenu fond-gris">
    <div class="conteneur-offre">

        <a href="index.php?page=offres" class="lien-retour">← Retour aux offres</a>

        <div class="grille-details">

            <!-- GAUCHE -->
            <article class="details-principaux boite-blanche">
                <div class="en-tete-offre">
                    <div class="titre-et-badges">
                        <span class="badge-nouveau">Nouveau</span>
                        <h1>{{ offre.titre }}</h1>
                        <p class="entreprise-lieu">
                            <strong>{{ offre.nom_entreprise }}</strong> • {{ offre.ville }}
                        </p>
                    </div>
                </div>

                <div class="liste-criteres">
                    <div class="critere">
                        <span>📅</span>
                        <div>
                            <strong>Durée</strong>
                            <span>{{ offre.duree_stage }} mois</span>
                        </div>
                    </div>

                    <div class="critere">
                        <span>🎓</span>
                        <div>
                            <strong>Niveau</strong>
                            <span>Stage</span>
                        </div>
                    </div>

                    <div class="critere">
                        <span>💻</span>
                        <div>
                            <strong>Compétence</strong>
                            <span>{{ offre.competence }}</span>
                        </div>
                    </div>

                    <div class="critere">
                        <span>💰</span>
                        <div>
                            <strong>Gratification</strong>
                            <span>{{ offre.remuneration }} € / mois</span>
                        </div>
                    </div>
                </div>

                <div class="description-complete">
                    <h2>Description du poste</h2>
                    <p>{{ offre.description }}</p>
                </div>
            </article>

            <!-- DROITE -->
            <aside class="barre-laterale">

                <div class="boite-blanche carte-action">
                    <h3>Intéressé(e) ?</h3>

                    {% if session.user is defined and session.user.role == 'etudiant' %}
                        <a href="index.php?page=postuler&id={{ offre.id_offre }}" class="btn-postuler-grand">
                            Postuler maintenant
                        </a>
                    {% else %}
                        <button class="btn-postuler-grand" disabled>
                            Réservé aux étudiants
                        </button>
                    {% endif %}

                    {% if session.user is defined %}
                        <a href="index.php?page=wishlist-ajouter&id={{ offre.id_offre }}" class="btn-wishlist-secondaire">
                            Ajouter à la wish-list
                        </a>
                    {% else %}
                        <a href="index.php?page=connexion" class="btn-wishlist-secondaire">
                            Ajouter à la wish-list
                        </a>
                    {% endif %}
                </div>

                <div class="boite-blanche carte-entreprise">
                    <div class="logo-entreprise-placeholder">
                        {{ offre.nom_entreprise|slice(0, 2)|upper }}
                    </div>
                    <h3>{{ offre.nom_entreprise }}</h3>
                    <p>{{ offre.ville }}</p>
                    <a href="index.php?page=entreprise&id={{ offre.id_entreprise }}">
                        Voir l'entreprise ↗
                    </a>
                </div>

            </aside>

        </div>
    </div>
</main>

<footer class="pied-de-page">
    <p>&copy; 2026 AlloStage</p>
</footer>
<script>
const openBtn  = document.getElementById('open-menu');
const closeBtn = document.getElementById('close-menu');
const menu     = document.getElementById('menu-burger');
const overlay  = document.getElementById('menu-overlay');

function openMenu() {
    menu.classList.add('active');
    overlay.classList.add('active');
}

function closeMenu() {
    menu.classList.remove('active');
    overlay.classList.remove('active');
}

if (openBtn)  openBtn.addEventListener('click', openMenu);
if (closeBtn) closeBtn.addEventListener('click', closeMenu);
if (overlay)  overlay.addEventListener('click', closeMenu);
</script>
</body>
</html>