<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Détail de l’offre - BHStage</title>
  <link rel="stylesheet" href="/public/css/offre.css">
</head>
<body>
  <main class="page-offre">

    <header class="barre-haut">
      <a href="liste-offres.php" class="bouton-retour">←</a>
      <a href="menu.php" class="bouton-profil">👤</a>
    </header>

    <section class="presentation-offre">
      <h1>{{ offre.titre }}</h1>

      <div class="entreprise-ligne">
        <div class="entreprise-logo"></div>

        <div class="entreprise-texte">
          <h2>{{ offre.nom_entreprise ?? 'Entreprise' }}</h2>
          <p class="localisation">📍 Ville à compléter</p>
        </div>
      </div>

      <p class="informations-offre">
        Publiée le {{ offre.date_publication|date('d/m/Y') }}
      </p>
    </section>

    <section class="bloc-description">
      <h2>Description de l’offre</h2>
      <p>
        {{ offre.description }}
      </p>
    </section>

    <section class="grille-infos">
      <article class="carte-info">
        <h3>Durée</h3>
        <p>📅 {{ offre.duree_stage }}</p>
      </article>

      <article class="carte-info">
        <h3>Compétences</h3>
        <div class="etiquettes">
          <span>{{ offre.competence }}</span>
        </div>
      </article>

      <article class="carte-info">
        <h3>Base de rémunération</h3>
        <p>{{ offre.remuneration }} € / mois</p>
      </article>
    </section>

    <section class="bloc-profil">
      <h2>Profil recherché</h2>
      <p>
        Profil à décrire (ajoute une colonne plus tard si tu veux le stocker en base).
      </p>
    </section>

    <section class="actions-bas">
      <a href="postuler.php?id={{ offre.id_offre }}" class="bouton-postuler">Postuler</a>
    </section>

  </main>
</body>
</html>