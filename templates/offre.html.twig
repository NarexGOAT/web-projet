<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Détail de l’offre - BHStage</title>
  <link rel="stylesheet" href="/css/offre.css">
</head>
<body>
  <main class="page-offre">

    <header class="barre-haut">
      <a href="index.php?page=offres" class="bouton-retour">←</a>
      <a href="index.php?page=menu" class="bouton-profil">👤</a>
    </header>

    <section class="presentation-offre">
      <h1>{{ offre.titre }}</h1>

      <div class="entreprise-ligne">
        <div class="entreprise-logo"></div>

        <div class="entreprise-texte">
          <h2>{{ offre.nom_entreprise ?? 'Entreprise' }}</h2>
          <p class="localisation">
            📍 {{ offre.ville ?? 'Ville non renseignée' }}
          </p>
        </div>
      </div>

      <p class="informations-offre">
        Publiée le {{ offre.date_publication|date('d/m/Y') }}
      </p>
    </section>

    <section class="bloc-description">
      <h2>Description de l’offre</h2>
      <p>
        {{ offre.description }}
      </p>
    </section>

    <section class="grille-infos">
      <article class="carte-info">
        <h3>Durée</h3>
        <p>📅 {{ offre.duree_stage }} semaines</p>
      </article>

      <article class="carte-info">
        <h3>Compétences</h3>
        <div class="etiquettes">
          <span>{{ offre.competence }}</span>
        </div>
      </article>

      <article class="carte-info">
        <h3>Base de rémunération</h3>
        <p>{{ offre.remuneration }} € / mois</p>
      </article>
    </section>

    <section class="bloc-profil">
      <h2>Profil recherché</h2>
      <p>
        Compétences attendues : {{ offre.competence }}.
      </p>
    </section>

    <section class="actions-bas">
  {% if session.user_id is defined %}
    {% if deja_candidature %}
      <p class="message-candidature">
        Vous avez déjà postulé à cette offre.
      </p>
      <a href="index.php?page=candidatures" class="bouton-postuler">
        Voir mes candidatures
      </a>
    {% else %}
      <a href="index.php?page=postuler&id={{ offre.id_offre }}" class="bouton-postuler">
        Postuler
      </a>
    {% endif %}

    <a href="index.php?page=wishlist-ajouter&id={{ offre.id_offre }}" class="bouton-wishlist">
      Ajouter à ma wish-list
    </a>
  {% else %}
    <a href="index.php?page=connexion" class="bouton-postuler">
      Se connecter pour postuler
    </a>
    <a href="index.php?page=connexion" class="bouton-wishlist">
      Se connecter pour ajouter à la wish-list
    </a>
  {% endif %}
</section>

  </main>
</body>
</html>