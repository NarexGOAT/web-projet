<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Réinitialiser le mot de passe - BHStage</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/public/css/connexion.css">
</head>
<body>

    <div class="login-container">
        
        <div class="header-text" style="margin-top: 20px;">
            <h2>Réinitialiser votre mot de passe</h2>
        </div>

        <form action="nouveau-mdp.php" class="login-form">
            
            <div class="input-group">
                <label for="email">Email</label>
                <input type="email" id="email" placeholder="Votre adresse mail" required>
            </div>

            <div class="input-group">
                <label for="code">Code de vérification</label>
                <input type="text" id="code" placeholder="Votre code de vérification" required>
            </div>

            <div class="checkbox-group">
                <input type="checkbox" id="confirm-reset" required>
                <label for="confirm-reset">Réinitialiser mon mot de passe pour en créer un nouveau.</label>
            </div>

            <button type="submit" class="btn-submit">Continue</button>

        </form>

    </div>

</body>
</html>