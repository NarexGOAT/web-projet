<!DOCTYPE html>
<html lang="fr-FR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AlloStage</title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

<header class="barre-haut">
  <div class="conteneur barre-haut__interieur">

    <a href="index.php">
      <img src="/images/allostage.png" class="logo-img" style="height:70px;">
    </a>

    <form class="recherche">
      <input type="search" placeholder="Rechercher une offre...">
    </form>

    <nav class="actions">
      <a href="index.php?page=wishlist">❤️</a>
      <a href="index.php?page=menu">👤</a>
    </nav>

  </div>
</header>

<main class="page">
  <div class="conteneur">

    <section class="mise-en-avant">
      <h1>Des offres adaptées à ton profil</h1>

      <p>
        BHStage centralise les offres et te propose celles adaptées.
      </p>

      <div>
        <strong>{{ total_offres }}</strong> offres<br>
        <strong>{{ total_entreprises }}</strong> entreprises
      </div>
    </section>

    <section>
      <h2>Dernières offres</h2>

      {% for offre in dernieres_offres %}
        <div>
          <h3>{{ offre.titre }}</h3>
          <p>{{ offre.description }}</p>
        </div>
      {% endfor %}

    </section>

  </div>
</main>

</body>
</html>