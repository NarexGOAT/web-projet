<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>AlloStage — Accueil</title>
  <meta name="description" content="BHStage centralise des offres de stage et met en relation les étudiants avec des entreprises partenaires.">
  <link rel="stylesheet" href="/css/style.css">
</head>

<body>
  <header class="barre-haut">
    <div class="conteneur barre-haut__interieur">
      <a class="bhstage" href="index.php">
        <span class="nom">AlloStage</span>
      </a>

      <form class="recherche" role="search">
        <span class="recherche__icone">🔍</span>
        <input
          class="recherche__champ"
          id="recherche-site"
          type="search"
          name="q"
          placeholder="Rechercher une offre, une entreprise...">
      </form>

      <nav class="actions">
        <a class="bouton-icone" href="index.php?page=wishlist" title="Favoris">❤️</a>
        <a href="index.php?page=menu" class="bouton-profil">👤</a>
      </nav>
    </div>  
  </header>

  <main class="page">
    <div class="conteneur">
      <section class="disposition">

        <section class="carte mise-en-avant">
          <h1 class="mise-en-avant__titre">Des offres adaptées à ton profil, au même endroit.</h1>

          <p class="mise-en-avant__texte">
            BHStage centralise les offres de stage d’entreprises partenaires et te propose celles
            qui correspondent à tes compétences. Postule simplement et gagne du temps.
          </p>

          <nav class="mise-en-avant__actions" aria-label="Actions principales">
            <a class="bouton bouton--principal" href="index.php?page=offres">Voir toutes les offres</a>
            <a class="bouton bouton--secondaire" href="#dernieres-offres">Voir les dernières</a>
            <a class="bouton bouton--principal" href="index.php?page=entreprises">Voir toutes les entreprises</a>
          </nav>

          <section>
            <ul class="mise-en-avant__stats">
              <li>
                <strong>{{ total_offres }}</strong>
                <span>offres actives</span>
              </li>
              <li>
                <strong>{{ total_entreprises }}</strong>
                <span>entreprises</span>
              </li>
              <li>
                <strong>1 clic</strong>
                <span>pour postuler</span>
              </li>
            </ul>
          </section>
        </section>

        <aside class="colonne-droite">
          <header class="entete-section" id="dernieres-offres">
            <h2>Dernières offres</h2>
            <a class="lien" href="index.php?page=offres">Tout voir →</a>
          </header>

          {% for offre in dernieres_offres %}
            <article class="carte offre">
              {# Étiquette "il y a X jours" simplifiée #}
              <span class="etiquette">
                Publiée le {{ offre.date_publication|date('d/m') }}
              </span>

              <header class="offre__entete">
                <h3 class="offre__titre">{{ offre.titre }}</h3>
              </header>

              <p class="offre__description">
                {{ offre.description|length > 120 ? offre.description|slice(0, 120) ~ '...' : offre.description }}
              </p>

              <dl class="offre__infos">
                <div class="offre__ligne">
                  <dt>Compétences</dt>
                  <dd>{{ offre.competence }}</dd>
                </div>
                <div class="offre__ligne">
                  <dt>Publiée le</dt>
                  <dd>{{ offre.date_publication|date('d/m') }}</dd>
                </div>
              </dl>

              <footer class="offre__actions">
  <a class="bouton bouton--doux" href="index.php?page=offre&id={{ offre.id_offre }}">Voir l’offre</a>

  {% if session.user_id is defined %}
    <a class="bouton bouton--icone"
       href="index.php?page=wishlist-ajouter&id={{ offre.id_offre }}"
       title="Ajouter à la wish-list">
      ⭐
    </a>
  {% else %}
    <a class="bouton bouton--icone"
       href="index.php?page=connexion"
       title="Se connecter pour ajouter à la wish-list">
      ⭐
    </a>
  {% endif %}

  <p class="entreprise">{{ offre.nom_entreprise ?? 'Entreprise non renseignée' }}</p>
</footer>
            </article>
          {% else %}
            <p>Aucune offre pour le moment.</p>
          {% endfor %}

        </aside>
      </section>
    </div>
  </main>

  <footer class="pied-page">
    <div class="conteneur pied-page__interieur">
      <small>© BHStage</small>
      <a href="index.php?page=mentions">Mentions légales</a>
    </div>
  </footer>
  {% if wishlist_added %}
<script>
  alert('L’offre a bien été ajoutée à la wish-list.');
</script>
{% endif %}

{% if wishlist_exists %}
<script>
  alert('Cette offre est déjà dans votre wish-list.');
</script>
{% endif %}
</body>
</html>